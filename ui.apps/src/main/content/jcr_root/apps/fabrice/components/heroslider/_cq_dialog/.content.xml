<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
          xmlns:cq="http://www.day.com/jcr/cq/1.0"
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Hero Slider"
          sling:resourceType="cq/gui/components/authoring/dialog">
    <content jcr:primaryType="nt:unstructured"
             sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <tabs jcr:primaryType="nt:unstructured"
                  sling:resourceType="granite/ui/components/coral/foundation/tabs"
                  maximized="{Boolean}true">
                <items jcr:primaryType="nt:unstructured">
                    <slides jcr:primaryType="nt:unstructured"
                            jcr:title="Slides"
                            sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                            margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <column jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <slidesmultifield
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                                        composite="{Boolean}true"
                                        fieldLabel="Slides">
                                        <field jcr:primaryType="nt:unstructured"
                                               sling:resourceType="granite/ui/components/coral/foundation/container"
                                               name="./slides">
                                            <items jcr:primaryType="nt:unstructured">
                                                <image jcr:primaryType="nt:unstructured"
                                                       sling:resourceType="granite/ui/components/coral/foundation/form/pathfield"
                                                       fieldLabel="Image"
                                                       name="./image"
                                                       rootPath="/content/dam"/>
                                                <title jcr:primaryType="nt:unstructured"
                                                       sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                       fieldLabel="Title"
                                                       name="./title"
                                                       required="{Boolean}true"/>
                                                <pretitle jcr:primaryType="nt:unstructured"
                                                         sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                         fieldLabel="Pre-title (optional)"
                                                         name="./pretitle"/>
                                                <subtitle jcr:primaryType="nt:unstructured"
                                                          sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                          fieldLabel="Subtitle (optional)"
                                                          name="./subtitle"/>
                                                <ctaLink jcr:primaryType="nt:unstructured"
                                                         sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                         fieldLabel="CTA Link (optional, URL or path)"
                                                         name="./ctaLink"/>
                                                <ctaText jcr:primaryType="nt:unstructured"
                                                         sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                                         fieldLabel="CTA Text (optional)"
                                                         name="./ctaText"/>
                                            </items>
                                        </field>
                                    </slidesmultifield>
                                </items>
                            </column>
                        </items>
                    </slides>
                    <settings jcr:primaryType="nt:unstructured"
                              jcr:title="Settings"
                              sling:resourceType="granite/ui/components/coral/foundation/fixedcolumns"
                              margin="{Boolean}true">
                        <items jcr:primaryType="nt:unstructured">
                            <column jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/container">
                                <items jcr:primaryType="nt:unstructured">
                                    <autoplaySpeed jcr:primaryType="nt:unstructured"
                                                   sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                                   fieldLabel="Autoplay delay (ms)"
                                                   name="./autoplaySpeed"
                                                   value="5000"/>
                                    <showNavigation jcr:primaryType="nt:unstructured"
                                                     sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                                                     fieldLabel="Show navigation arrows"
                                                     name="./showNavigation"
                                                     checked="{Boolean}true"
                                                     text="Show"
                                                     value="true"/>
                                </items>
                            </column>
                        </items>
                    </settings>
                </items>
            </tabs>
        </items>
    </content>
</jcr:root>
