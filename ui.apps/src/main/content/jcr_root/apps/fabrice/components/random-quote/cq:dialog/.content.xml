<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" 
          xmlns:cq="http://www.day.com/jcr/cq/1.0" 
          xmlns:jcr="http://www.jcp.org/jcr/1.0"
          xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
          xmlns:granite="http://www.adobe.com/jcr/granite/1.0"
          jcr:primaryType="nt:unstructured"
          jcr:title="Random Quote"
          sling:resourceType="cq/gui/components/authoring/dialog">
    
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            
            <!-- Main tab -->
            <main
                jcr:primaryType="nt:unstructured"
                jcr:title="Quotes"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                    
                    <!-- Title field -->
                    <title
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                        fieldLabel="Component Title"
                        name="./title"
                        emptyText="Enter a title (optional)"/>
                    
                    <!-- Multifield for quotes -->
                    <quotes
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/multifield"
                        fieldLabel="Quotes"
                        fieldDescription="Add quotes to display randomly"
                        name="./quotes"
                        composite="{Boolean}true">
                        <field
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="granite/ui/components/coral/foundation/container">
                            <items jcr:primaryType="nt:unstructured">
                                
                                <!-- Quote text -->
                                <quoteText
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    name="./quote"
                                    fieldLabel="Quote"
                                    emptyText="Enter the quote text"
                                    required="{Boolean}true"/>
                                
                                <!-- Author -->
                                <author
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    name="./author"
                                    fieldLabel="Author"
                                    emptyText="Enter the author name"/>
                                
                                <!-- Year (optional) -->
                                <year
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                    name="./year"
                                    fieldLabel="Year"
                                    emptyText="Optional year"/>
                            </items>
                        </field>
                    </quotes>
                </items>
            </main>
            
            <!-- Settings tab -->
            <settings
                jcr:primaryType="nt:unstructured"
                jcr:title="Settings"
                sling:resourceType="granite/ui/components/coral/foundation/container">
                <items jcr:primaryType="nt:unstructured">
                    
                    <!-- Auto-refresh option -->
                    <autoRefresh
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/checkbox"
                        text="Auto-refresh quote"
                        name="./autoRefresh"
                        value="{Boolean}true"/>
                    
                    <!-- Refresh interval (if auto-refresh is checked) -->
                    <refreshInterval
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                        fieldLabel="Refresh interval (seconds)"
                        name="./refreshInterval"
                        min="{Long}2"
                        max="{Long}60"
                        value="{Long}5"
                        required="{Boolean}true"/>
                </items>
            </settings>
        </items>
    </content>
</jcr:root>